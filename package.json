{
  "name": "pdf-reader",
  "version": "0.1.0",
  "description": "High-precision PDF-to-Markdown conversion system with Gemini AI",
  "type": "module",
  "scripts": {
    "start": "tsx src/orchestrator.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "node-poppler": "^9.1.1",
    "ora": "^9.3.0",
    "p-limit": "^7.3.0",
    "pdfjs-dist": "^5.6.205",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
